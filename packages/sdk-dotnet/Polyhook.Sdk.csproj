<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <PackageId>Polyhook.Sdk</PackageId>
    <Version>0.1.0</Version>
    <AssemblyName>Polyhook.Sdk</AssemblyName>
    <RootNamespace>Polyhook</RootNamespace>
    <Description>C# SDK for polyhook — write AI coding agent hooks once, run them everywhere.</Description>
    <Authors>polyhook</Authors>
    <LicenseExpression>MIT</LicenseExpression>
    <PackageProjectUrl>https://github.com/tupe12334/polyhook</PackageProjectUrl>
    <RepositoryUrl>https://github.com/tupe12334/polyhook</RepositoryUrl>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <CollectCoverage>true</CollectCoverage>
    <CoverletOutputFormat>opencover</CoverletOutputFormat>
    <Exclude>[*]*.GeneratedTypes</Exclude>
  </PropertyGroup>
  <ItemGroup>
    <Compile Remove="PolyhookTests/**/*.cs" />
    <Compile Remove="*Tests.cs" />
    <Compile Remove="examples/**/*.cs" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Wasmtime" Version="14.0.0" />
    <PackageReference Include="System.Text.Json" Version="9.0.0" />
  </ItemGroup>
  <ItemGroup>
    <EmbeddedResource Include="polyhook.wasm" />
    <None Include="README.md" Pack="true" PackagePath="/" />
  </ItemGroup>
</Project>
